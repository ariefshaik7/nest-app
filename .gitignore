# ====================================================================
# 🌍 TERRAFORM, OPENTOFU, TERRAGRUNT & CDKTF (COMPLETE ENTERPRISE)
# ====================================================================

# Local execution directories (plugins, modules, cache)
.terraform/
.tofu/

# Local state files & tracking (NEVER commit state files, they contain secrets!)
*.tfstate
*.tfstate.*
*.tofu.tfstate
*.tofu.tfstate.*

# Concurrent run lock files
.terraform.tfstate.lock.info
.tofu.tfstate.lock.info

# Generated plans and variable configurations
*.tfplan
*.tfvars
*.tfvars.json
*.tofuvars
*.tofuvars.json

# Terragrunt execution caches and outputs
.terragrunt-cache/
terragrunt-debug.log

# CDKTF (Cloud Development Kit for Terraform) artifacts
.gen/
cdktf.out/

# Terraspace framework generation directories
.terraspace/

# Override files (local developer overrides)
*.tfoverride
*.tfoverride.json
*.tofuoverride
*.tofuoverride.json

# CLI configuration files containing provider tokens/credentials
.terraformrc
terraform.rc
tofurc
tofu.rc

# tflint (Terraform linter) caches
.tflint.hcl

*/.terraform.lock.hcl

