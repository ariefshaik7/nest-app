
# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Optional: You may want to ignore override files that contain sensitive information.
# Override files typically contain paranoid security settings.
# resource "aws_s3_bucket" "s3_bucket" {
#   lifecycle {
#     prevent_destroy = true
#   }
# }
# example_override.tf
# *.override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

.DS_Store


# ====================================================================
# MASTER UNIVERSAL GITIGNORE (Development, DevOps, Cloud & Security)
# ====================================================================

# --------------------------------------------------------------------
# 🛑 SECURITY & SECRETS (NEVER COMMIT THESE)
# --------------------------------------------------------------------
*.pem
*.key
*.pub
*.crt
*.p12
*.pfx
*.pkcs12
*.secret
*.kube/config
*kubeconfig*
.vault-token
*history
.bash_history
.zsh_history

# --------------------------------------------------------------------
# ⚙️ ENVS, CONFIGS, & CREDENTIALS
# --------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.env
config.json
secrets.*
credentials.json
.aws/credentials
.aws/config

